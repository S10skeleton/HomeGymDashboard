{
  "name": "forge-gym",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FORGE GYM OS — local-network home gym dashboard",
  "scripts": {
    "dev": "concurrently -n server,client -c red,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^6.0.3"
  }
}
